begin mrbayes;
  set autoclose=yes nowarn=yes;
  lset nst=mixed rates=gamma;
  prset aamodelpr=mixed;
  mcmc ngen=500000 samplefreq=500 printfreq=5000 nruns=2 nchains=4;
  sumt burnin=250;
  sump burnin=250;
end;
